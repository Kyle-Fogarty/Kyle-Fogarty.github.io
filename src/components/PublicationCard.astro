---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { Publication, VenueType } from '../data/publications';

interface Props {
  pub: Publication;
}

const { pub } = Astro.props;

const venueChip: Record<VenueType, string> = {
  conference: 'chip--blue',
  journal: 'chip--green',
  workshop: 'chip--orange',
  preprint: 'chip--pink',
};

// Eagerly load every cover figure so we can look one up by its base filename
// (extension-agnostic). Missing files simply fall through to a placeholder.
const coverModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/pub/*.{png,jpg,jpeg,webp,avif}',
  { eager: true },
);

const coversByName = new Map<string, ImageMetadata>();
for (const [path, mod] of Object.entries(coverModules)) {
  const name = path.split('/').pop()!.replace(/\.[^.]+$/, '');
  coversByName.set(name, mod.default);
}

const cover = pub.image ? coversByName.get(pub.image) : undefined;
---

<article class="card pub">
  <div class={`pub-thumb ${venueChip[pub.venueType]}`}>
    {
      cover ? (
        <Image
          src={cover}
          alt={`Teaser figure from “${pub.title}”`}
          width={480}
          height={300}
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="pub-thumb-placeholder" aria-hidden="true">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="3" y="4" width="18" height="16" rx="2" />
            <circle cx="8.5" cy="9.5" r="1.5" />
            <path d="m3 16 4.5-4.5a2 2 0 0 1 2.8 0L15 16" />
            <path d="m13 14 2-2a2 2 0 0 1 2.8 0L21 15" />
          </svg>
        </div>
      )
    }
  </div>

  <div class="pub-body">
    <div class="pub-meta">
      <span class={`chip ${venueChip[pub.venueType]}`}>{pub.venue} {pub.year}</span>
      {pub.note && <span class="pub-note">{pub.note}</span>}
      {pub.selected && <span class="pub-selected">Selected</span>}
    </div>
    <h3 class="pub-title">{pub.title}</h3>
    <p class="pub-authors">
      {
        pub.authors.map((author, i) => (
          <>
            {author === 'Kyle Fogarty' ? <strong>{author}</strong> : author}
            {i < pub.authors.length - 1 && ', '}
          </>
        ))
      }
    </p>
    {
      pub.links.length > 0 && (
        <div class="pub-links">
          {pub.links.map((link) => (
            <a href={link.url}>{link.label} ↗</a>
          ))}
        </div>
      )
    }
  </div>
</article>

<style>
  .pub {
    display: grid;
    grid-template-columns: 190px 1fr;
    gap: 1.35rem;
    align-items: start;
  }

  .pub-thumb {
    position: relative;
    aspect-ratio: 16 / 10;
    border-radius: 0.6rem;
    overflow: hidden;
    background: var(--bg-soft);
    border: 1px solid var(--border);
  }

  .pub-thumb :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pub-thumb-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--chip, var(--pastel-blue)) 20%, var(--bg-soft));
  }

  .pub-thumb-placeholder svg {
    width: 30%;
    max-width: 2rem;
    height: auto;
    color: var(--text-faint);
    opacity: 0.65;
  }

  .pub-body {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    min-width: 0;
  }

  .pub-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .pub-selected {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-faint);
  }

  .pub-note {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text);
    background: color-mix(in srgb, var(--pastel-green) var(--chip-mix), var(--bg-card));
    border: 1px solid color-mix(in srgb, var(--pastel-green) var(--chip-border-mix), var(--bg-card));
    border-radius: 999px;
    padding: 0.06rem 0.5rem;
  }

  :root[data-theme='dark'] .pub-note {
    color: color-mix(in srgb, var(--pastel-green) 45%, var(--text));
  }

  .pub-title {
    font-size: 1.125rem;
    line-height: 1.35;
  }

  .pub-authors {
    color: var(--text-muted);
    font-size: 0.9375rem;
    line-height: 1.55;
  }

  .pub-authors strong {
    color: var(--text);
    font-weight: 600;
  }

  .pub-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }

  .pub-links a {
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 500;
  }

  .pub-links a:hover {
    color: var(--text);
    text-decoration: underline;
  }

  /* Stack the thumbnail above the text on narrow screens. */
  @media (max-width: 640px) {
    .pub {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .pub-thumb {
      max-width: 100%;
    }
  }
</style>
