---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---

<Base
  title="Blog — Kyle Fogarty"
  description="Notes and writeups on 3D graphics, computer vision, and machine learning research."
>
  <section class="section">
    <div class="container">
      <p class="section-label">Blog</p>
      <h1 class="section-title">Notes &amp; writeups</h1>
      {
        posts.length === 0 ? (
          <p class="empty">Nothing here yet — check back soon.</p>
        ) : (
          <div class="post-list">
            {posts.map((post) => (
              <a class="card post-card" href={`/blog/${post.id}/`}>
                <span class="post-date">{formatDate(post.data.date)}</span>
                <h2 class="post-title">{post.data.title}</h2>
                {post.data.description && <p class="post-desc">{post.data.description}</p>}
              </a>
            ))}
          </div>
        )
      }
    </div>
  </section>
</Base>

<style>
  .empty {
    color: var(--text-muted);
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 44rem;
  }

  .post-card {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-faint);
    font-weight: 500;
  }

  .post-title {
    font-size: 1.25rem;
  }

  .post-desc {
    color: var(--text-muted);
    font-size: 0.9575rem;
  }
</style>
